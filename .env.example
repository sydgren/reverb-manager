# ─── Single-app mode ──────────────────────────────────────────────────
# Each consuming Laravel app uses these to sign subscriptions and
# publish broadcasts. Set these for the simplest setup.
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=replace-me

# ─── Multi-app mode ───────────────────────────────────────────────────
# Set REVERB_APPS to a JSON array (REVERB_APP_* above is ignored).
# Each app needs at minimum app_id / key / secret. Other fields fall
# back to sensible defaults.
#
# REVERB_APPS='[
#   {"app_id":"webhook-dev","key":"wd-key","secret":"wd-sec","allowed_origins":["https://hooks.example.com"]},
#   {"app_id":"crm","key":"crm-key","secret":"crm-sec","allowed_origins":["https://crm.example.com"]}
# ]'

# ─── Server bind ──────────────────────────────────────────────────────
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ─── Optional: scaling via Redis pub/sub ──────────────────────────────
# REVERB_SCALING_ENABLED=true
# REDIS_URL=redis://redis:6379
