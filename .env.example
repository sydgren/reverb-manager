# Required. Each consuming Laravel app uses these to sign subscriptions
# and publish broadcasts.
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=replace-me

# Bind address (where Reverb listens inside the container).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Optional. Set if you want Reverb to know its public hostname for cookies.
# REVERB_HOST=ws.hooks.example.com
